{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "bun",
      "request": "launch",
      "name": "Debug Current Example (Bun)",
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "runtime": "${userHome}/AppData/Roaming/npm/node_modules/bun/bin/bun.exe",
      "stopOnEntry": false,
      "watchMode": false,
      "internalConsoleOptions": "openOnSessionStart"
    }
  ]
}
